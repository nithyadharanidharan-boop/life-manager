{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/index.js" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/favicon.svg", "dest": "/public/favicon.svg" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
